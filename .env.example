# ═══════════════════════════════════════════════════════════════════════════════
# Ajosave Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your actual values.
#
# [REQUIRED] — App will not start without this variable (validated by src/lib/env.ts)
# [OPTIONAL] — Has a safe default or is only needed for specific features
#
# ⚠️  NEVER_COMMIT — Variables marked ⚠️ NEVER_COMMIT contain secrets.
#     Never commit them to git or share them publicly.
#     Add .env.local to .gitignore (it is already excluded by default in this repo).
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App Configuration ─────────────────────────────────────────────────────────

# [REQUIRED] Base URL where your app is deployed
# Use http://localhost:3000 for local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [REQUIRED] Application name displayed in the UI and outgoing emails
NEXT_PUBLIC_APP_NAME=Ajosave

# [OPTIONAL] Comma-separated list of allowed origins for cross-origin API requests (CORS)
# Example: https://my-other-app.com,https://staging.my-other-app.com
# Leave blank to allow only NEXT_PUBLIC_APP_URL
# ALLOWED_ORIGINS=http://localhost:3000

# [OPTIONAL] Log level for the pino logger (default: info)
# Options: trace | debug | info | warn | error | fatal
# Set to "debug" locally for verbose output; keep "warn" or "error" in production
LOG_LEVEL=info

# ─── Authentication (NextAuth.js) ──────────────────────────────────────────────

# [REQUIRED] Must match NEXT_PUBLIC_APP_URL exactly
# NextAuth uses this to build callback URLs
NEXTAUTH_URL=http://localhost:3000

# [REQUIRED] Secret key for signing JWT tokens and encrypting session cookies
# How to generate: openssl rand -base64 32
# ⚠️  NEVER_COMMIT
NEXTAUTH_SECRET=replace_with_strong_random_secret

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Local:      postgresql://postgres:password@localhost:5432/ajosave
# Production: Obtain from your hosting provider (Vercel Postgres, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/ajosave

# [OPTIONAL] SSL mode for the PostgreSQL connection (default: auto-detected from STELLAR_NETWORK)
# Options: require | no-verify | disable
# Defaults: mainnet → require, testnet → no-verify, local → disable
# DATABASE_SSL_MODE=no-verify

# [OPTIONAL] Maximum number of DB connections in the pool (default: 10)
# Tune based on your database plan (e.g., Vercel Postgres supports up to 100 connections)
DB_POOL_SIZE=10

# [OPTIONAL] Minimum number of idle DB connections to keep warm (default: 2)
# Set to 0–1 for development; 2–5 for production to reduce cold-start latency
DB_POOL_MIN=2

# [OPTIONAL] Timeout in ms before a new connection attempt fails (default: 5000)
DB_CONNECTION_TIMEOUT_MS=5000

# [OPTIONAL] Time in ms an idle connection is kept before being closed (default: 30000)
DB_IDLE_TIMEOUT_MS=30000

# [OPTIONAL] Number of times a failed query is retried before throwing (default: 3)
DB_MAX_RETRIES=3

# [OPTIONAL] Delay in ms between retry attempts — multiplied by attempt number (default: 500)
# e.g., attempt 1 → 500ms, attempt 2 → 1000ms, attempt 3 → 1500ms
DB_RETRY_DELAY_MS=500

# ─── Stellar Blockchain ────────────────────────────────────────────────────────

# [REQUIRED] Network to connect to
# Options: testnet | mainnet
# Use testnet for all local development — no real funds involved
STELLAR_NETWORK=testnet

# [REQUIRED] Horizon REST API endpoint for the selected network
# Testnet: https://horizon-testnet.stellar.org
# Mainnet: https://horizon.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# [OPTIONAL] Secondary Horizon endpoint used as a failover if the primary is unavailable
# Mainnet fallback options: https://horizon.stellar.org  or  https://horizon.stellar.lobstr.co
STELLAR_HORIZON_FALLBACK_URL=

# [REQUIRED] Network passphrase included in every signed transaction
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# [REQUIRED] Soroban RPC endpoint for submitting and reading smart contract transactions
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# [REQUIRED] Stellar secret key for the server/platform wallet
# Purpose: Signs Stellar transactions and manages USDC transfers on behalf of the platform
# How to generate:
#   Testnet (free):  https://laboratory.stellar.org/#account-creator
#   Or via CLI:      stellar keys generate --network testnet
# Format: Starts with 'S', 56 characters total
# ⚠️  NEVER_COMMIT
STELLAR_SERVER_SECRET_KEY=replace_with_stellar_secret_key

# [OPTIONAL] Deployed Soroban Ajo contract address — used by the event indexer and reputation fallback ONLY
#
# NOTE: Ajosave uses per-circle contract deployment. Each savings circle gets its own Soroban
#       contract instance (deployed automatically when the last member joins). The per-circle
#       contract address is stored in the circles.contract_id database column — NOT here.
#
# This variable is used ONLY by:
#   1. event-indexer.service.ts  — polls a single contract for platform-level event streaming
#   2. reputation.ts             — fallback when no explicit contractId is supplied
#
# Leave blank if you do not need global event indexing or reputation fallback.
# See docs/adr/001-per-circle-contract-deployment.md for the full architecture decision.
# Testnet value: CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
STELLAR_AJO_CONTRACT_ID=

# [OPTIONAL] Soroban contract address for minting on-chain completion certificates
# Purpose: Issues a Soroban NFT certificate when a member completes a savings circle
# Leave blank to disable certificate minting (a warning will be logged at startup)
STELLAR_CERTIFICATE_CONTRACT_ID=

# [OPTIONAL] Maximum Stellar transaction fee in stroops (default: 200)
# 1 stroop = 0.0000001 XLM. Increase if transactions are failing due to fee competition.
STELLAR_MAX_FEE_CAP=200

# [OPTIONAL] Enable/disable live Horizon payment streaming (default: true)
# Set to 'false' to disable real-time incoming USDC payment detection
ENABLE_HORIZON_STREAM=true

# [OPTIONAL] Enable/disable the Soroban contract event indexer (default: true)
# Set to 'false' to disable on-chain circle event indexing for the dashboard
ENABLE_EVENT_INDEXER=true

# [OPTIONAL] Polling interval for the event indexer in milliseconds (default: 15000)
EVENT_INDEXER_POLL_MS=15000

# ─── USDC Stablecoin ───────────────────────────────────────────────────────────

# [REQUIRED] Stellar address of the USDC issuer
# Testnet: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# [REQUIRED] Asset code for USDC on Stellar (always USDC)
USDC_ASSET_CODE=USDC

# [OPTIONAL] Maximum allowed price slippage when swapping NGN → USDC, as a percentage (default: 0.5)
# Example: 0.5 means the swap will fail if the received USDC is more than 0.5% below the quoted rate
SLIPPAGE_TOLERANCE_PERCENT=0.5

# ─── Payments (Paystack) ───────────────────────────────────────────────────────
# Paystack dashboard: https://dashboard.paystack.com/#/settings/developer

# [REQUIRED] Paystack secret key for server-side API calls (charge, verify, transfer)
# Format: sk_test_... (test) or sk_live_... (production)
# ⚠️  NEVER_COMMIT
PAYSTACK_SECRET_KEY=replace_with_paystack_secret_key

# [REQUIRED] Paystack public key for the client-side checkout popup
# Format: pk_test_... (test) or pk_live_... (production)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=replace_with_paystack_public_key

# [OPTIONAL] Paystack subaccount code for automatic platform fee splits
# How to get: Paystack Dashboard → Subaccounts → Create Subaccount
# Format: ACCT_xxxxxxxxxxxxxxx
PAYSTACK_PLATFORM_SUBACCOUNT=

# [OPTIONAL] Platform fee percentage deducted from each contribution (default: 0.5)
# Example: 0.5 means 0.5% of each contribution goes to the platform subaccount
PLATFORM_FEE_PERCENT=0.5

# ─── SMS & OTP (Termii) ────────────────────────────────────────────────────────
# Termii dashboard: https://termii.com/dashboard → API Settings

# [REQUIRED] Termii API key for sending SMS OTP and payout notifications
# ⚠️  NEVER_COMMIT
TERMII_API_KEY=replace_with_termii_api_key

# [REQUIRED] Sender ID shown to recipients in SMS messages (max 11 characters)
# Must be registered and approved by Termii before use
TERMII_SENDER_ID=Ajosave

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Resend dashboard: https://resend.com/api-keys

# [OPTIONAL] Resend API key for transactional email (contribution receipts, payout notices)
# Leave blank to disable email notifications; SMS-only mode will still work
# ⚠️  NEVER_COMMIT
RESEND_API_KEY=

# [OPTIONAL] From address used in all outgoing emails (default: Ajosave <noreply@ajosave.app>)
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL=Ajosave <noreply@ajosave.app>

# ─── Redis (Cache & Queue) ─────────────────────────────────────────────────────

# [REQUIRED] Redis connection URL
# Local:      redis://localhost:6379
# Production: Obtain from your provider (Upstash, Redis Cloud, Railway, etc.)
# Use rediss:// (with double 's') for TLS connections
REDIS_URL=redis://localhost:6379

# ─── PII Encryption ────────────────────────────────────────────────────────────
# Used by src/lib/encryption.ts to encrypt phone numbers and emails at rest (AES-256-GCM + HMAC-SHA256)

# [REQUIRED for PII encryption] 64 hex characters = 32 bytes, used for AES-256-GCM field encryption
# How to generate: openssl rand -hex 32
# ⚠️  NEVER_COMMIT — loss of this key makes encrypted PII irrecoverable
PII_ENCRYPTION_KEY=replace_with_64_hex_chars

# [REQUIRED for PII encryption] 64 hex characters = 32 bytes, used for HMAC-SHA256 searchable indexes
# How to generate: openssl rand -hex 32
# Must be different from PII_ENCRYPTION_KEY
# ⚠️  NEVER_COMMIT
PII_HMAC_KEY=replace_with_64_hex_chars

# ─── KYC (Smile Identity) ──────────────────────────────────────────────────────
# Smile Identity portal: https://portal.smileidentity.com → Settings → API Keys

# [REQUIRED for KYC] Smile Identity partner ID
SMILE_PARTNER_ID=replace_with_smile_partner_id

# [REQUIRED for KYC] Smile Identity API key (used to sign webhook payloads)
# ⚠️  NEVER_COMMIT
SMILE_API_KEY=replace_with_smile_api_key

# [OPTIONAL] AWS Secrets Manager ARN for the Smile Identity API key
# When set, overrides SMILE_API_KEY and enables zero-downtime key rotation via AWS
# Example: arn:aws:secretsmanager:us-east-1:123456789012:secret:ajosave/smile-api-key-XXXXXX
# SMILE_API_KEY_SECRET_ARN=

# [REQUIRED for KYC] Public URL that Smile Identity POSTs verification results to
# Example: https://yourdomain.com/api/v1/kyc/webhook
SMILE_CALLBACK_URL=https://yourdomain.com/api/v1/kyc/webhook

# [OPTIONAL] NGN contribution amount above which KYC verification is required (default: 100000)
# Circles with a contribution_fiat value >= this threshold will block unverified members
KYC_THRESHOLD_NGN=100000

# ─── Referral System ───────────────────────────────────────────────────────────

# [OPTIONAL] Type of reward granted to referrers (default: fee_waiver)
# Options: fee_waiver | credit | none
REFERRAL_REWARD_TYPE=fee_waiver

# ─── WalletConnect ─────────────────────────────────────────────────────────────
# WalletConnect dashboard: https://cloud.walletconnect.com

# [OPTIONAL] WalletConnect project ID for Freighter wallet deep-link support
# Required only if you want to enable the WalletConnect wallet integration
# How to get: https://cloud.walletconnect.com → Create Project
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Cron Jobs ─────────────────────────────────────────────────────────────────

# [REQUIRED] Secret token for authenticating requests to /api/cron/* endpoints
# Include this in the Authorization header: Authorization: Bearer <CRON_SECRET>
# How to generate: openssl rand -hex 32
# ⚠️  NEVER_COMMIT
CRON_SECRET=replace_with_cron_secret

# ─── Log Aggregation (Datadog) ─────────────────────────────────────────────────
# Datadog dashboard: https://app.datadoghq.com → Organization Settings → API Keys

# [OPTIONAL] Datadog API key for shipping structured JSON logs via pino-datadog-transport
# Leave blank to disable Datadog log forwarding (logs will still go to stdout)
# ⚠️  NEVER_COMMIT
DATADOG_API_KEY=

# [OPTIONAL] Identifier for the log aggregation service (e.g., datadog, cloudwatch)
LOG_AGGREGATION_SERVICE=datadog

# ─── Monitoring (Sentry) ───────────────────────────────────────────────────────
# Sentry dashboard: https://sentry.io → Settings → Projects → Client Keys (DSN)

# [OPTIONAL] Sentry DSN for client-side error and performance tracking
# Format: https://public_key@org_id.ingest.sentry.io/project_id
NEXT_PUBLIC_SENTRY_DSN=https://replace@oXXXXXX.ingest.sentry.io/XXXXXXX

# [OPTIONAL] Sentry DSN for server-side error tracking (usually the same as above)
SENTRY_DSN=https://replace@oXXXXXX.ingest.sentry.io/XXXXXXX

# [OPTIONAL] Sentry organization slug (found in your Sentry URL)
SENTRY_ORG=ajosave

# [OPTIONAL] Sentry project slug
SENTRY_PROJECT=ajosave-nextjs

# [OPTIONAL] Sentry auth token for automatic source map uploads during build
# How to get: Sentry → Settings → Auth Tokens → Create New Token
# Permissions: project:releases, project:write
# ⚠️  NEVER_COMMIT
SENTRY_AUTH_TOKEN=replace_with_sentry_auth_token

# ─── Alerts (Slack) ────────────────────────────────────────────────────────────

# [OPTIONAL] Slack incoming webhook URL for critical alerts (failed payouts, missed contributions, etc.)
# How to get: https://api.slack.com/messaging/webhooks → Create App → Incoming Webhooks
# Format: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/with/webhook

# ═══════════════════════════════════════════════════════════════════════════════
# Quick Start Checklist
# ═══════════════════════════════════════════════════════════════════════════════
# 1.  Copy this file:          cp .env.example .env.local
# 2.  Generate secrets:
#       NEXTAUTH_SECRET:        openssl rand -base64 32
#       CRON_SECRET:            openssl rand -hex 32
#       PII_ENCRYPTION_KEY:     openssl rand -hex 32
#       PII_HMAC_KEY:           openssl rand -hex 32
# 3.  Set up PostgreSQL (local or hosted) and update DATABASE_URL
# 4.  Create a Stellar testnet account:
#       https://laboratory.stellar.org/#account-creator
#       Then set STELLAR_SERVER_SECRET_KEY
# 5.  Deploy the Ajo contract:  npm run contract:deploy
#       Then set STELLAR_AJO_CONTRACT_ID to the printed contract ID
# 6.  Sign up for required services:
#       Paystack:  https://paystack.com  (PAYSTACK_SECRET_KEY, NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY)
#       Termii:    https://termii.com    (TERMII_API_KEY)
# 7.  (Optional) Sign up for monitoring:
#       Sentry:    https://sentry.io
#       Datadog:   https://datadoghq.com
#       Slack:     https://api.slack.com/messaging/webhooks
# 8.  Run migrations:           npm run migrate
# 9.  Start the dev server:     npm run dev
# ═══════════════════════════════════════════════════════════════════════════════
